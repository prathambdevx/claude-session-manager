# Personal / local state — never publish. Contains your session names, tickets, notes,
# context briefings, and agent-job outputs.
data/*
# ...except the generated tmux config — tracked on this branch while the tmux work is in progress
# so it's easy to see/tweak. (main keeps all of data/ ignored; the per-machine tmux-state.json /
# terminal.json stay ignored everywhere.)
!data/tmux.conf

# Logs
*.log

# Dependencies (none currently, but just in case)
node_modules/

# macOS
.DS_Store

# Playwright MCP scratch screenshots/traces
.playwright-mcp/
